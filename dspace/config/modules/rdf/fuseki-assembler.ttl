@prefix fuseki:  <http://jena.apache.org/fuseki#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tdb2:    <http://jena.apache.org/2016/tdb#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix ja:      <http://jena.hpl.hp.com/2005/11/Assembler#> .
@prefix :        <#> .

###########################
#### Server description ###
###########################
[] rdf:type fuseki:Server ;
   fuseki:services (
     <#service1>
   ) .

#################
### Service 1 ###
#################
<#service1> rdf:type fuseki:Service ;
    fuseki:name                       "server" ;
    fuseki:serviceQuery               "sparql" ;
    #nessun accesso in scrittura da api
    #fuseki:serviceReadWriteGraphStore "data" ;
    fuseki:serviceReadGraphStore      "get" ;
    fuseki:dataset                    <#dspace-triplestore> ;
    .

<#dspace-triplestore>  rdf:type    tdb2:DatasetTDB ;
    tdb2:location "/opt/triplestore-fuseki" ;
    # Enable this only if the query default graph must be the union of all named graphs.
    # Note: with this setting, the persisted default graph is ignored by normal queries; if data is loaded in the default graph and there are no named graphs, SELECT ?s ?p ?o returns 0.
    tdb2:unionDefaultGraph true ;
    .