<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:util="http://www.springframework.org/schema/util"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
                        http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
                        http://www.springframework.org/schema/util
                        http://www.springframework.org/schema/util/spring-util-3.0.xsd">

	<bean class="org.dspace.content.authority.AuthorityNameAuthorityFilter">
		<property name="supportedAuthorities">
			<util:list>
				<value>FondsLeafAuthority</value>
				<value>JournalFondsLeafAuthority</value>
				<value>AggregationLeafAuthority</value>
			</util:list>
		</property>
		<constructor-arg name="customQueries">
			<util:list>
				<value>glam.leaf:true</value>
			</util:list>
		</constructor-arg>
	</bean>

	<bean class="org.dspace.content.authority.AuthorityNameAuthorityFilter">
		<property name="supportedAuthorities">
			<util:list>
				<value>FondsAuthority</value>
				<value>JournalFondsParentAuthority</value>
				<value>AggregationAuthority</value>
			</util:list>
		</property>
		<constructor-arg name="customQueries">
			<util:list>
				<value>-glam.leaf:true</value>
			</util:list>
		</constructor-arg>
	</bean>


	<bean class="org.dspace.content.authority.AuthorityNameAuthorityFilter">
		<property name="supportedAuthorities">
			<util:list>
				<value>LibroAnticoAuthority</value>
			</util:list>
		</property>
		<constructor-arg name="customQueries">
			<util:list>
				<value>location.coll:"e296f188-a264-485e-a621-97f4465c660f" OR location.coll:"d8205d51-4f77-459f-b17c-4c7ce4c74dab" OR location.coll:"3e94096a-2eb5-44fb-97bf-00d95b5032e0" OR location.coll:"f5c26551-d224-4f84-b1d0-509fe40e999d" OR location.coll:"1ff5156f-30f5-435f-86d7-ec3328ec88a3" OR location.coll:"656d31db-4393-4390-bf89-6a5a32fff3cb" OR location.coll:"480ca547-1f5d-4f19-aa5d-3540797776e0" OR location.coll:"9b8d78bc-c0ed-46b8-9fed-73ecb67b094e" OR location.coll:"af1a64af-a91b-4388-93c6-fd442fe31979" OR location.coll:"bb524986-e0c9-47bc-a911-b8c13d753209" OR location.coll:"b3a1aebb-7291-4254-a48e-b5c286e57549" OR location.coll:"faebad4d-fbac-420d-b7ba-95344c2ef5e0"</value>
			</util:list>
		</constructor-arg>
	</bean>


	<bean class="org.dspace.content.authority.AuthorityNameAuthorityFilter">
		<property name="supportedAuthorities">
			<util:list>
				<value>AldovrandiManoscrittiAuthority</value>
			</util:list>
		</property>
		<constructor-arg name="customQueries">
			<util:list>
				<value>location.coll:"cd9e126d-1a35-4b15-af8d-4cffb2319175"</value>
			</util:list>
		</constructor-arg>
	</bean>

	<bean class="org.dspace.content.authority.AuthorityNameAuthorityFilter">
		<property name="supportedAuthorities">
			<util:list>
				<value>PublicationReferencesAuthority</value>
			</util:list>
		</property>
		<constructor-arg name="customQueries">
			<util:list>
				<value>-dc.type:("interactive resource" OR website OR dataset OR image OR "moving image" OR video OR "still image" OR other OR software OR workflow OR "cartographic material" OR map OR sound OR "musical composition" OR patent)</value>
			</util:list>
		</constructor-arg>
	</bean>
	

</beans>