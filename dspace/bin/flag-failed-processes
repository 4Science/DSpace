# This is a Unix shell script that would flag as failed any process with a
# pending status listed in the file failed-processes.txt in the dspace.dir
# (if no file is present exit immediately)

# Assume that this script is in the bin subdirectory of the DSpace installation directory.
BINDIR=`dirname $0`
DSPACEDIR=`cd "$BINDIR/.." ; pwd`
PIDS_FILE=$DSPACEDIR/failed-processes.txt

# Check if the file with the pids exists
if [ -e "$PIDS_FILE" ]; then
    echo "PIDs File exists."
else
    echo "PIDs File does not exist."
    exit 1
fi

# Read the file and generate the comma-separated string
PROCESS_PIDS="-1"

while IFS= read -r line; do
    # Skip empty lines
    if [ -z "$line" ]; then
        continue
    fi
    if [ -n "$PROCESS_PIDS" ]; then
        PROCESS_PIDS="$PROCESS_PIDS,$line"
    else
        PROCESS_PIDS="$line"
    fi
done < "$PIDS_FILE"

echo $PROCESS_PIDS

DB_USERNAME=`$BINDIR/dspace dsprop --property db.username`
DB_PASSWORD=`$BINDIR/dspace dsprop --property db.password`
export PGPASSWORD=$DB_PASSWORD
DB_URL=`$BINDIR/dspace dsprop --property db.url`

# Strip the prefix
url_without_prefix=$(echo "$DB_URL" | sed 's/^jdbc:postgresql:\/\///')

# Extract the host, port and name
DB_HOST=$(echo "$url_without_prefix" | cut -d':' -f1)
DB_PORT=$(echo "$url_without_prefix" | cut -d':' -f2 | cut -d'/' -f1)
DB_NAME=$(echo "$url_without_prefix" | cut -d'/' -f2 | cut -d'?' -f1)

/usr/bin/psql $DB_NAME -p $DB_PORT -h $DB_HOST -U $DB_USERNAME -t \ 
-c "update process set finished_time = NOW(), status = 'FAILED' where process_id in ($PROCESS_PIDS) and status in ('RUNNING', 'SCHEDULED');"